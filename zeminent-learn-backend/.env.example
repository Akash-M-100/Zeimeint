# Template file — copy to .env and fill in real values.
# NEVER commit real secrets here. .env is gitignored; this file is schema only.

NEST_API_URL=
API_URL=

# ===== AWS S3 + CloudFront (video + thumbnail storage/delivery) =====
# S3 stores lecture videos (uploaded by the browser via presigned PUT) and
# course thumbnails. CloudFront signs playback URLs when configured; otherwise
# the server falls back to S3 presigned GET URLs.
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_VIDEO_BUCKET=
# Optional — enable signed CloudFront playback URLs.
AWS_CLOUDFRONT_DOMAIN=
AWS_CLOUDFRONT_KEY_PAIR_ID=
AWS_CLOUDFRONT_PRIVATE_KEY_PATH=

SESSION_SECRET=

OAUTH_BRIDGE_SECRET=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=

# ===== Razorpay (payments) =====
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Get from Razorpay Dashboard → Settings → Webhooks after creating the
# webhook pointing at https://<your-domain>/api/payments/webhook.
# Unset → webhook endpoint returns 503; client-side /verify still works.
RAZORPAY_WEBHOOK_SECRET=

# ===== Seller info (required for GST tax invoices, Slice 14 B.1+) =====
# Used on every tax invoice PDF and as the source of seller GSTIN +
# stateCode that determines CGST+SGST vs IGST treatment. Server fails to
# start (clear error) if any of the required fields is missing.
SELLER_LEGAL_NAME=
SELLER_GSTIN=
SELLER_STATE_CODE=
SELLER_STATE=
SELLER_ADDRESS_LINE_1=
SELLER_ADDRESS_LINE_2=
SELLER_CITY=
SELLER_DISTRICT=
SELLER_PINCODE=
